# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with repo + workflow scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The GitHub organization or username that owns the repos
GITHUB_ORG=your-org-name

# ─── Jenkins ──────────────────────────────────────────────────────────────────
# Base URL of your Jenkins server (no trailing slash)
JENKINS_URL=https://jenkins.your-company.com
# Jenkins username
JENKINS_USER=your-username
# Jenkins API token (not your password) — generate at /user/<name>/configure
JENKINS_TOKEN=your-api-token

# ─── Jira ─────────────────────────────────────────────────────────────────────
# Jira Cloud base URL (no trailing slash)
JIRA_URL=https://your-company.atlassian.net
# Email address associated with the Jira account
JIRA_EMAIL=you@company.com
# Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your-api-token

# ─── Defaults (can be overridden per row in the UI) ───────────────────────────
DEFAULT_TARGET_BRANCH=env/staging
TAG_PREFIX=env-stag

# ─── Database ─────────────────────────────────────────────────────────────────
# Used when running locally without Docker (Docker Compose sets these automatically).
# The values below match the PostgreSQL container defaults in docker-compose.yml.
DATABASE_USER=deploymate
DATABASE_PASSWORD=deploymate
